<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.coraise.ruida.runtime.culture.mapper.SysFilesClientMapper">

    <!-- 批量插入文化知识库数据-->
    <insert id="insertFilesBath" parameterType="list">
        INSERT INTO sys_files(id, url)
        VALUES
        <foreach collection="list" item="item" index="index" separator=",">
            (
            #{item.id}, #{item.url}
             )
        </foreach>
        on duplicate key update
        id = values(id), url = VALUES(url)
    </insert>


</mapper>